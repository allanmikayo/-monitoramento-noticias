# Copie para ".env" e ajuste. Nenhum destes valores deve ir para o Git.

# Banco de dados. Deixe em branco para usar o SQLite local (data/credit_monitor.db).
# Quando migrar para a nuvem, aponte para o Postgres do Supabase -- use a
# connection string "Connection pooling" / "Transaction mode" (porta 6543),
# não a "Direct connection", e prefixo postgresql+psycopg:// (não psycopg2),
# ex.:
# DATABASE_URL=postgresql+psycopg://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Modo nuvem (deixe em branco localmente): quando hospedado no Vercel, essas
# duas variáveis fazem o botão "Forçar atualização" acionar o robô no GitHub
# Actions em vez de tentar rodar o Playwright no próprio processo do site
# (que não funciona em função serverless). Ver DEPLOY.md.
GITHUB_TOKEN=
GITHUB_REPO=

# Segredo do endpoint /api/cron-trigger (deixe em branco localmente) --
# gere uma string aleatória e cadastre o MESMO valor no serviço externo de
# cron (cron-job.org) que vai chamar esse endpoint a cada 5 min de verdade,
# já que o cron nativo do GitHub Actions não é pontual. Ver DEPLOY.md.
CRON_SECRET=

# Chave usada para assinar cookies de sessão — gere uma string aleatória longa.
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-longa

# Primeiro usuário admin, criado automaticamente na primeira execução.
BOOTSTRAP_ADMIN_EMAIL=allancruz078@gmail.com
BOOTSTRAP_ADMIN_NAME=Allan
BOOTSTRAP_ADMIN_PASSWORD=troque-esta-senha

# E-mail (confirmação de cadastro). Se deixar em branco, o link de confirmação
# só aparece no console/log — útil para testar localmente sem SMTP configurado.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=monitoramento@seudominio.com

# URL pública do app (usada para montar o link de confirmação de e-mail)
APP_BASE_URL=http://localhost:8765

# Intervalo do scanner automático, em minutos
SCAN_INTERVAL_MINUTES=5

# Duração da sessão de login, em minutos
SESSION_TTL_MINUTES=480
